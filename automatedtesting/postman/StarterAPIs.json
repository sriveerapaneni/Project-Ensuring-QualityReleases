			"name": "Data Validation Tests",
			"item": [
				{
					"name": "Get All Activities - Data Validation",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Status Code Validation",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Response Time Validation",
									"pm.test(\"Response time is less than 2000ms\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(2000);",
									"});",
									"",
									"// Content Type Validation",
									"pm.test(\"Content-Type is application/json\", function () {",
									"    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
									"});",
									"",
									"// Response Body Validation",
									"pm.test(\"Response is an array\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"});",
									"",
									"// Data Structure Validation (case-insensitive keys)",
									"pm.test(\"Activities have required fields\", function () {",
									"    function hasKeyCI(obj, key){ return Object.keys(obj).some(k=>k.toLowerCase()===key.toLowerCase()); }",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.length > 0) {",
									"        pm.expect(hasKeyCI(jsonData[0], 'id')).to.be.true;",
									"        pm.expect(hasKeyCI(jsonData[0], 'title')).to.be.true;",
									"        pm.expect(hasKeyCI(jsonData[0], 'dueDate')).to.be.true;",
									"        pm.expect(hasKeyCI(jsonData[0], 'completed')).to.be.true;",
									"    }",
									"});",
									"",
									"// Data Type Validation (case-insensitive access)",
									"pm.test(\"Activity fields have correct data types\", function () {",
									"    function getValCI(obj, key){ var k=Object.keys(obj).find(k=>k.toLowerCase()===key.toLowerCase()); return k?obj[k]:undefined; }",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.length > 0) {",
									"        pm.expect(getValCI(jsonData[0], 'id')).to.be.a('number');",
									"        pm.expect(getValCI(jsonData[0], 'title')).to.be.a('string');",
									"        pm.expect(getValCI(jsonData[0], 'completed')).to.be.a('boolean');",
									"    }",
									"});",
									"",
									"// Save first activity ID for later tests (case-insensitive)",
									"if (pm.response.json().length > 0) {",
									"    var first = pm.response.json()[0];",
									"    var k = Object.keys(first).find(k=>k.toLowerCase()==='id');",
									"    if(k) pm.environment.set(\"activityId\", first[k]);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/Activities",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"Activities"
							]
						}
					},
					"response": []
				},
